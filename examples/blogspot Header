let currentScene = 0;
let currentProfile = "desktop";
let currentState = "IDLE";
let currentAction = "OBSERVE";
let typeTimeout = null;

const specDOM = {
  viewport: document.getElementById("spec-viewport"),
  scene: document.getElementById("spec-scene"),
  visual: document.getElementById("spec-visual"),
  fade: document.getElementById("spec-fade"),
  output: document.getElementById("spec-output"),
  overlay: document.getElementById("spec-overlay"),
  actionBtn: document.getElementById("action"),
  infoScene: document.getElementById("info-scene"),
  infoState: document.getElementById("info-state"),
  infoAction: document.getElementById("info-action")
};

function detectProfile() {
  currentProfile = window.innerWidth <= 768 ? "mobile" : "desktop";
}

function typeOutput(text) {
  if (!text) return;
  if (typeTimeout) clearTimeout(typeTimeout);
  
  specDOM.output.textContent = "";
  let i = 0;
  
  function writeChar() {
    if (i < text.length) {
      specDOM.output.textContent += text.charAt(i);
      i++;
      typeTimeout = setTimeout(writeChar, specConfig.typingSpeed);
    }
  }
  writeChar();
}

function look(position) {
  if (currentState === "TRANSITION" || currentState === "LOOKING") return;
  
  const sceneData = specScenes[currentScene];
  if (!sceneData || !sceneData[currentProfile][position]) return;
  
  currentState = "LOOKING";
  currentAction = position.toUpperCase();
  
  specDOM.visual.classList.remove("spec-channel-switch");
  void specDOM.visual.offsetWidth; 
  specDOM.visual.classList.add("spec-channel-switch");
  
  const transformCoordinates = sceneData[currentProfile][position];
  specDOM.scene.style.transform = transformCoordinates;
  
  typeOutput(sceneData.texts[position]);
  
  const sceneName = sceneData.name;
  
  // --- ATOMIZZAZIONE DEL RESET ED EVITAMENTO DEL CONFLITTO ---
  if (sceneName === "SPEC 0" || sceneName === "SPEC 3") {
    // 1. Svuota completamente la memoria di questa scena prima di inserire il nuovo nodo
    const directions = ["left", "up", "focusA", "focusB", "down", "right"];
    directions.forEach(pos => {
      specMemory.visitedNodes.delete(`${currentScene}_${pos}`);
    });
    
    // 2. Spegne tutti i nodi visivamente
    document.querySelectorAll(".spec-interface .spec-node").forEach(btn => {
      if (btn.id !== "action") btn.classList.remove("visited");
    });
    
    // 3. Registra SOLO il nodo corretto se l'azione corrisponde alla chiave di sblocco
    if ((sceneName === "SPEC 0" && position === "right") || (sceneName === "SPEC 3" && position === "down")) {
      const nodeKey = `${currentScene}_${position}`;
      specMemory.visitedNodes.add(nodeKey);
      const buttonClicked = document.querySelector(`.spec-interface button[data-dir="${position}"]`);
      if (buttonClicked) buttonClicked.classList.add("visited");
    } else {
      // Se clicca il tasto sbagliato in SPEC 0 o SPEC 3, accendilo temporaneamente senza salvarlo come sblocco
      const buttonClicked = document.querySelector(`.spec-interface button[data-dir="${position}"]`);
      if (buttonClicked) buttonClicked.classList.add("visited");
    }
  } else {
    // Meccanismo standard cumulativo per tutte le altre scene
    const nodeKey = `${currentScene}_${position}`;
    specMemory.visitedNodes.add(nodeKey);
    const buttonClicked = document.querySelector(`.spec-interface button[data-dir="${position}"]`);
    if (buttonClicked) buttonClicked.classList.add("visited");
  }
  
  // Esegui il controllo sblocchi quando lo stato è pulito
  checkUnlockConditions();
  
  setTimeout(() => {
    currentState = "IDLE";
    updateInfo();
  }, 350);

  updateInfo();
}

function checkUnlockConditions() {
  const sceneName = specScenes[currentScene].name;

  if (sceneName === "SPEC 0") {
    if (currentAction === "RIGHT") {
      specDOM.actionBtn.classList.add("unlocked");
      specMemory.unlockedActions.add(currentScene);
    } else {
      specDOM.actionBtn.classList.remove("unlocked");
      specMemory.unlockedActions.delete(currentScene);
    }
  } else if (sceneName === "SPEC 3") {
    // SBLOCCO AGGANCIATO RIGIDAMENTE A DOWN PER LA SCENA DELLA FORESTA
    if (currentAction === "DOWN") {
      specDOM.actionBtn.classList.add("unlocked");
      specMemory.unlockedActions.add(currentScene);
    } else {
      specDOM.actionBtn.classList.remove("unlocked");
      specMemory.unlockedActions.delete(currentScene);
    }
  } else if (currentScene === 6) {
    specDOM.actionBtn.classList.add("unlocked");
  } else {
    const required = ["left", "up", "focusA", "focusB", "down", "right"];
    let visitedAll = true;
    
    required.forEach(pos => {
      if (!specMemory.visitedNodes.has(`${currentScene}_${pos}`)) {
        visitedAll = false;
      }
    });
    
    if (visitedAll) {
      specDOM.actionBtn.classList.add("unlocked");
      specMemory.unlockedActions.add(currentScene);
    } else {
      specDOM.actionBtn.classList.remove("unlocked");
      specMemory.unlockedActions.delete(currentScene);
    }
  }
}

function nextScene() {
  if (!specDOM.actionBtn.classList.contains("unlocked")) return;
  if (currentState === "TRANSITION") return;
  
  currentState = "TRANSITION";
  specDOM.fade.style.opacity = "1";
  specDOM.actionBtn.classList.remove("unlocked");
  
  setTimeout(() => {
    if (currentScene === 6) {
      currentScene = 0;
      document.body.classList.remove("spec-konami");
    } else {
      currentScene = (currentScene + 1);
      if (currentScene >= 6) { 
        currentScene = 0; 
      }
    }
    
    loadScene();
    
    setTimeout(() => {
      specDOM.fade.style.opacity = "0";
      currentState = "IDLE";
      currentAction = "OBSERVE";
      updateInfo();
    }, 50);
  }, 600);
}


function loadScene() {
  const sceneData = specScenes[currentScene];
  if (!sceneData) return;
  
  specDOM.visual.style.backgroundImage = `url('${sceneData.image}')`;

  const sceneName = sceneData.name;
  if (sceneName === "SPEC 0" || sceneName === "SPEC 3") {
    specDOM.actionBtn.style.transition = "opacity 5s ease-in-out";
    specDOM.actionBtn.style.transitionDelay = "1s";
  } else {
    specDOM.actionBtn.style.transition = "none";
    specDOM.actionBtn.style.transitionDelay = "0s";
  }
  
  const directions = ["left", "up", "focusA", "focusB", "down", "right"];
  directions.forEach(pos => {
    specMemory.visitedNodes.delete(`${currentScene}_${pos}`);
  });
  
  specDOM.actionBtn.classList.remove("unlocked");
  document.querySelectorAll(".spec-interface .spec-node").forEach(btn => {
    if (btn.id !== "action") btn.classList.remove("visited");
  });
  
  const centerCoord = sceneData[currentProfile]["center"];
  specDOM.scene.style.transform = centerCoord;
  
  checkUnlockConditions();

  // --- DA QUI: NUOVO SISTEMA DI OUTPUT CRITTOGRAFICO CASUALE ---
  const crypticMessages = [
    `0096`,
    `2251`,
    `2110`,
    `8105`
  ];

  const randomMessage = crypticMessages[Math.floor(Math.random() * crypticMessages.length)];
  typeOutput(randomMessage);
  // --- A QUI ---

  updateInfo();

  if (sceneName === "SPEC 1") { 
    specDOM.visual.style.backgroundSize = "contain"; 
    specDOM.visual.style.backgroundPosition = "left center"; 
  } else {
    specDOM.visual.style.backgroundSize = "contain";
    specDOM.visual.style.backgroundPosition = "center center";
  }
}

function updateInfo() {
  if(specDOM.infoScene) specDOM.infoScene.textContent = specScenes[currentScene].name;
  if(specDOM.infoState) specDOM.infoState.textContent = currentState;
  if(specDOM.infoAction) specDOM.infoAction.textContent = currentAction;
}

const konamiPattern = ["ArrowUp", "ArrowUp", "ArrowDown", "ArrowDown", "ArrowLeft", "ArrowRight", "ArrowLeft", "ArrowRight", "b", "a"];
let konamiIndex = 0;

function registerKonamiInput(key) {
  const cleanKey = key.length === 1 ? key.toLowerCase() : key;
  if (cleanKey === konamiPattern[konamiIndex]) {
    konamiIndex++;
    if (konamiIndex === konamiPattern.length) {
      konamiIndex = 0; 
      document.body.classList.add("spec-konami");
      
      currentScene = 6; 
      currentState = "TRANSITION";
      specDOM.fade.style.opacity = "1";
      
      setTimeout(() => {
        loadScene();
        setTimeout(() => {
          specDOM.fade.style.opacity = "0";
          currentState = "IDLE";
          currentAction = "OBSERVE";
          updateInfo();
        }, 50);
      }, 600);

      typeOutput("ACCESS GRANTED: KONAMI PROTOCOL -> SPEC 6 UNLOCKED");
    }
  } else {
    konamiIndex = 0; 
  }
}

document.addEventListener("keydown", event => {
  switch(event.key) {
    case "ArrowLeft":  look("left");   registerKonamiInput("ArrowLeft"); break;
    case "ArrowUp":    look("up");     registerKonamiInput("ArrowUp"); break;
    case "ArrowRight": look("right");  registerKonamiInput("ArrowRight"); break;
    case "ArrowDown":  look("down");   registerKonamiInput("ArrowDown"); break;
    case "b": case "B": registerKonamiInput("b"); break;
    case "a": case "A": registerKonamiInput("a"); break;
  }
});

function bindNodes() {
  document.querySelectorAll(".spec-interface .spec-node").forEach(button => {
    button.addEventListener("click", () => {
      const dir = button.getAttribute("data-dir");
      if (dir) {
        look(dir);
        
        // --- MAPPATURA COMPLETA COMPRESI I TASTI DI AZIONE DEL MOUSE ---
        if (dir === "left") registerKonamiInput("ArrowLeft");
        if (dir === "up") registerKonamiInput("ArrowUp");
        if (dir === "right") registerKonamiInput("ArrowRight");
        if (dir === "down") registerKonamiInput("ArrowDown");
        if (dir === "focusA") registerKonamiInput("a"); // ◐ diventa A
        if (dir === "focusB") registerKonamiInput("b"); // ◑ diventa B
        
      } else if (button.id === "action") {
        nextScene();
      }
    });
  });
}

document.addEventListener("DOMContentLoaded", () => {
  detectProfile();
  window.addEventListener("resize", detectProfile);
  bindNodes();
  loadScene(); 
});
