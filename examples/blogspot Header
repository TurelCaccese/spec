<style>
/*==============================================================
SPEC FRAMEWORK - HEADER5 (FIXED INTERFACE LOGIC)
==============================================================*/
:root {
  --spec-black: #000;
  --spec-green: #33ff33;
  --spec-green-dark: #00aa00;
  --spec-red: #ff3030;
  --spec-red-dark: #990000;
  --spec-white: #ffffff;
  --spec-font: Consolas, monospace;
  --spec-width: 1400px;
  --spec-transition: .35s;
  --spec-radius: 6px;
  --spec-ratio: 3/1;
}

@media(max-width:768px) {
  :root {
    --spec-ratio: 1/1;
  }
}

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  width: 100%;
  height: 100%;
  background: #000;
  color: var(--spec-green);
  font-family: var(--spec-font);
  overflow-x: hidden;
  padding: 10px;
  transition: background-color 0.3s ease, color 0.3s ease;
}

.spec-container {
  width: min(100%, var(--spec-width));
  margin: auto;
  padding: 20px;
  display: block;
}

/* EYE / VIEWPORT */
.spec-viewport {
  position: relative;
  width: 100%;
  aspect-ratio: var(--spec-ratio);
  overflow: hidden;
  background: #000;
  border: 2px solid var(--spec-green);
  box-shadow: 0 0 20px #00ff00;
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.spec-viewport::after {
  content: "";
  position: absolute;
  inset: 0;
  background: #000;
  pointer-events: none;
  opacity: 0;
  animation: specBlinkEye 12s infinite;
}

@keyframes specBlinkEye {
  0%, 94%, 100% { opacity: 0; }
  95% { opacity: 1; }
  96% { opacity: .2; }
  97% { opacity: 1; }
  98% { opacity: 0; }
}

.spec-camera {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
}

.spec-scene {
  position: absolute;
  width: 3200px;  
  height: 1800px; 
  left: -1000px;
  top: -700px;
  transition: transform 1s ease;
  transform-style: preserve-3d;
  transform-origin: center center;
  will-change: transform;
  backface-visibility: hidden;
}

.spec-visual {
  width: 100%;
  height: 100%;
  background-size: contain;
  background-repeat: no-repeat;
  background-position: 56% 58%;
  background-color: #000000;
  animation: specBlink 9s infinite, specFocus 14s infinite ease-in-out;
}

@keyframes specBlink {
  0%, 88%, 100% { filter: blur(0px) brightness(1); }
  92% { filter: blur(5px) brightness(.2); }
  96% { filter: blur(1px) brightness(.7); }
}

@keyframes specFocus {
  0%, 100% { filter: blur(0px); }
  50% { filter: blur(.8px); }
}

.spec-composition {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: none;
}

.spec-picture, .spec-frame {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}

.spec-overlay {
  position: absolute;
  inset: 0;
  pointer-events: none;
  opacity: 0;
  background: repeating-linear-gradient(
    0deg,
    rgba(0,0,0,.45) 0px,
    rgba(0,0,0,.45) 1px,
    transparent 1px,
    transparent 4px
  );
}

.spec-overlay-channel {
  animation: specOverlayChannel .45s ease-out;
}

@keyframes specOverlayChannel {
  0% { opacity: .7; }
  50% { opacity: .4; }
  100% { opacity: 0; }
}

.spec-fade {
  position: absolute;
  inset: 0;
  background: #000;
  opacity: 0;
  pointer-events: none;
  z-index: 99;
  transition: opacity .6s ease;
}

/* HAND / INTERFACE */
.spec-interface {
  display: flex;
  gap: 2px;
  margin-top: 6px;
}

.spec-node {
  flex: 1;
  height: 48px;
  background: #001100;
  color: #33ff33;
  border: 1px solid #33ff33;
  font-size: 20px;
  font-weight: bold;
  cursor: pointer;
  user-select: none;
  transition: transform .25s ease, filter .25s ease, box-shadow .25s ease, background-color .25s ease, border-color 0.3s ease, color 0.3s ease;
}

.spec-node:hover {
  filter: blur(.5px);
  transform: scale(1.05);
  box-shadow: 0 0 15px #33ff33;
}

.spec-node.visited {
  background: #004400;
  box-shadow: none;
}

.spec-node-action {
  opacity: 0;
  pointer-events: none;
}

/* Pulsante azione centrale con transizione lenta predefinita */
.spec-interface button[data-dir="center"], #action {
  opacity: 0;
  pointer-events: none; 
  transition: opacity 5s ease-in-out;
  transition-delay: 1s; 
}

.spec-interface button[data-dir="center"].unlocked, #action.unlocked {
  opacity: 1 !important;
  pointer-events: auto !important;
  background: #003300;
  box-shadow: 0 0 15px #33ff33, 0 0 30px #33ff33;
  animation: pulse 2s infinite;
}

@keyframes pulse {
  0%, 100% { box-shadow: 0 0 15px #33ff33; }
  50% { box-shadow: 0 0 30px #33ff33; }
}

body.spec-konami .spec-node-action.unlocked {
  animation: pulseRed 2s infinite;
}

@keyframes pulseRed {
  0%, 100% { box-shadow: 0 0 15px var(--spec-red); }
  50% { box-shadow: 0 0 30px var(--spec-red); }
}

.spec-output {
  flex: 2;
  height: 48px;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid #33ff33;
  color: #33ff33;
  background: #000;
  font-size: 13px;
  overflow: hidden;
  white-space: nowrap;
  text-align: center;
  margin-top: 6px;
  padding: 0 10px;
  transition: border-color 0.3s ease, color 0.3s ease;
}

.spec-info {
  display: flex;
  gap: 4px;
  margin-top: 6px;
  display: none;
}
.spec-info div {
  flex: 1;
  padding: 6px;
  border: 1px solid var(--spec-green);
  background: #001100;
  font-size: 11px;
  text-align: center;
  transition: border-color 0.3s ease, color 0.3s ease;
}

/* EFFECTS */
.spec-channel-switch {
  animation: specChannelSwitch .45s ease-out;
}
@keyframes specChannelSwitch {
  0% { filter: blur(3px) contrast(.6) brightness(.7); opacity:1; }
  20% { filter: blur(1px) contrast(.4) brightness(.5); }
  50% { filter: blur(2px) contrast(.8) brightness(.8); }
  100% { filter: none; }
}

/* KONAMI STATE GRAPHICS */
body.spec-konami {
  background: #110000;
  color: var(--spec-red);
}
body.spec-konami .spec-viewport {
  border-color: var(--spec-red);
  box-shadow: 0 0 20px var(--spec-red);
}
body.spec-konami .spec-node {
  background: #1a0000;
  color: var(--spec-red);
  border-color: var(--spec-red);
}
body.spec-konami .spec-node:hover {
  box-shadow: 0 0 15px var(--spec-red);
}
body.spec-konami .spec-node.visited {
  background: #440000;
}
body.spec-konami .spec-node-action.unlocked {
  background: #330000;
}
body.spec-konami .spec-node-action.unlocked:hover {
  box-shadow: 0 0 25px var(--spec-red), 0 0 50px var(--spec-red), 0 0 80px var(--spec-red);
}
body.spec-konami .spec-output,
body.spec-konami .spec-info div {
  border-color: var(--spec-red);
  color: var(--spec-red);
  background: #000;
}
</style>
